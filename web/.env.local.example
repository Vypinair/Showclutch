# ShowClutch — environment variables
# Copy this file to `.env.local` (same folder) and fill in your Supabase values.
# Find these in the Supabase dashboard: Project Settings -> Data API / API keys.
# `.env.local` is gitignored — your keys are never committed.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
